@model IEnumerable<UngDungOnThiBangLai.Models.TrafficSign>

@{
    ViewData["Title"] = "Thư viện biển báo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-uppercase"><i class="bi bi-signpost-split-fill text-primary"></i> Thư viện biển báo</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm"><i class="bi bi-plus-circle"></i> Thêm biển mới</a>
</div>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-5">
                <input type="text" name="searchString" class="form-control" placeholder="Tìm tên hoặc mã biển (P.102...)" value="@Context.Request.Query["searchString"]">
            </div>
            <div class="col-md-4">
                <select name="category" class="form-select">
                    <option value="">-- Tất cả loại biển --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat" selected="@(Context.Request.Query["category"] == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-filter"></i> Lọc dữ liệu</button>
            </div>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm hover-shadow transition">
                <div class="text-center p-3 bg-light" style="height: 160px; display: flex; align-items: center; justify-content: center;">
                    <img src="@item.ImageUrl" class="img-fluid" style="max-height: 140px;" alt="@item.Name">
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="badge bg-secondary">@item.Code</span>
                        <small class="text-muted">@item.Category</small>
                    </div>
                    <h6 class="card-title fw-bold text-dark text-truncate">@item.Name</h6>
                    <p class="card-text small text-muted text-truncate-2" style="height: 40px;">
                        @item.Description
                    </p>
                </div>
                <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center pb-3">
                    <div class="btn-group">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                              onsubmit="return confirm('Bạn chắc chắn muốn xóa biển báo này?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                    <span class="small text-primary fw-bold">ID: #@item.Id</span>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
        <p class="mt-3 text-muted">Không tìm thấy biển báo nào phù hợp.</p>
    </div>
}

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .transition {
        transition: all 0.3s ease;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>