@using UngDungOnThiBangLai.Models
@model LicenseCategory

@{
    ViewData["Title"] = "Thêm hạng bằng mới";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary py-3">
                    <h4 class="mb-0 fw-bold text-white"><i class="bi bi-plus-square-fill me-2"></i>THÊM HẠNG BẰNG MỚI</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" id="createLicenseForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4">
                            @* Thông tin cơ bản *@
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Tên hạng bằng (A1, B2, ...)</label>
                                <input asp-for="Name" class="form-control form-control-lg border-2 shadow-sm" placeholder="Nhập tên hạng bằng..." required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-dark">Tổng số câu hỏi/đề</label>
                                <input asp-for="TotalQuestions" type="number" class="form-control" value="25">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-dark">Thời gian thi (Phút)</label>
                                <input asp-for="TimeLimit" type="number" class="form-control" value="19">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-success">Số câu đúng tối thiểu</label>
                                <input asp-for="MinimumPassScore" type="number" class="form-control border-success-subtle" value="21">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-danger">Số câu điểm liệt/đề</label>
                                <input asp-for="TotalCriticalQuestions" type="number" class="form-control border-danger-subtle" value="1">
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-bold text-muted">Mô tả hạng bằng</label>
                                <textarea asp-for="Description" class="form-control shadow-sm" rows="2"></textarea>
                            </div>

                            @* Cấu hình ma trận chương *@
                            <div class="col-12 mt-4">
                                <div class="card border border-primary-subtle shadow-sm">
                                    <div class="card-header bg-primary-subtle d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0 fw-bold text-primary"><i class="bi bi-diagram-3-fill me-2"></i>CẤU HÌNH MA TRẬN CHƯƠNG</h6>
                                        <button type="button" id="add-topic" class="btn btn-sm btn-primary rounded-pill px-3">
                                            <i class="bi bi-plus-circle"></i> Thêm chương
                                        </button>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-hover align-middle">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width: 250px;">Tên chương</th>
                                                    <th>Mô tả</th>
                                                    <th style="width: 120px;" class="text-center">Số câu/đề</th>
                                                    <th style="width: 50px;"></th>
                                                </tr>
                                            </thead>
                                            <tbody id="topic-container">
                                                @* Hàng trống sẽ được thêm bằng JS *@
                                            </tbody>
                                        </table>
                                        <div id="no-topic-msg" class="text-center py-4">
                                            <i class="bi bi-inbox text-muted fs-2"></i>
                                            <p class="text-muted small mb-0">Chưa có chương nào. Hãy nhấn "Thêm chương" để cấu hình ma trận đề thi.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm fw-bold">
                                <i class="bi bi-cloud-check-fill me-1"></i> TẠO MỚI HẠNG BẰNG
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Logic thêm chương
            $('#add-topic').click(function (e) {
                e.preventDefault();
                $('#no-topic-msg').addClass('d-none');

                // Lấy index dựa trên số lượng tr hiện có
                let idx = $('#topic-container tr').length;

                let html = `
                    <tr class="topic-item">
                        <td>
                            <input name="QuestionTopics[${idx}].Name" class="form-control" required placeholder="Tên chương..." />
                        </td>
                        <td>
                            <input name="QuestionTopics[${idx}].Description" class="form-control" placeholder="Mô tả nội dung..." />
                        </td>
                        <td>
                            <input type="number" name="QuestionTopics[${idx}].NumberOfQuestionsInExam" class="form-control text-center" value="1" required min="1" />
                        </td>
                        <td>
                            <button type="button" class="btn btn-link text-danger remove-topic p-0"><i class="bi bi-trash fs-5"></i></button>
                        </td>
                    </tr>`;

                $('#topic-container').append(html);
            });

            // Logic xóa chương
            $(document).on('click', '.remove-topic', function () {
                $(this).closest('tr').remove();
                if ($('#topic-container tr').length === 0) {
                    $('#no-topic-msg').removeClass('d-none');
                }
            });

            // Logic Re-indexing trước khi submit (đảm bảo index liên tục 0,1,2...)
            $('#createLicenseForm').submit(function () {
                $('#topic-container tr').each(function (index, row) {
                    $(row).find('input').each(function () {
                        let name = $(this).attr('name');
                        if (name) {
                            let newName = name.replace(/\[\d+\]/, '[' + index + ']');
                            $(this).attr('name', newName);
                        }
                    });
                });
                return true;
            });
        });
    </script>
}