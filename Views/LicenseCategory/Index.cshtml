@using UngDungOnThiBangLai.Models
@model IEnumerable<LicenseCategory>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark"><i class="bi bi-card-checklist text-primary me-2"></i>QUẢN LÝ HẠNG BẰNG</h2>
            <p class="text-muted">Cấu hình thông số đề thi và ma trận chương cho từng hạng bằng lái</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle-fill me-1"></i> Thêm hạng bằng mới
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-2 custom-hover-card overflow-hidden">
                    <div class="card-body">
                        @* Header của Card *@
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <span class="badge bg-primary fs-5 px-3 shadow-sm">@item.Name</span>
                                <small class="text-muted d-block mt-1">ID: #@item.Id</small>
                            </div>
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" title="Chỉnh sửa cấu hình">
                                    <i class="bi bi-gear-fill"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Bạn có chắc chắn muốn xóa hạng bằng này? Toàn bộ cấu hình chương liên quan sẽ bị mất!')">
                                    <button type="submit" class="btn btn-outline-danger btn-sm border-start-0" title="Xóa hạng bằng">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <p class="text-muted small mb-3" style="min-height: 40px;">@(item.Description ?? "Không có mô tả.")</p>

                        @* Thông số đề thi *@
                        <div class="bg-light rounded p-3 mb-3">
                            <div class="row g-2 text-center">
                                <div class="col-6 border-end border-white">
                                    <small class="text-muted d-block">Số câu hỏi</small>
                                    <span class="fw-bold">@item.TotalQuestions</span>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Thời gian</small>
                                    <span class="fw-bold">@item.TimeLimit'</span>
                                </div>
                                <div class="col-6 border-end border-white border-top">
                                    <small class="text-muted d-block mt-1">Điểm đạt</small>
                                    <span class="fw-bold text-success">@item.MinimumPassScore</span>
                                </div>
                                <div class="col-6 border-top">
                                    <small class="text-muted d-block mt-1">Điểm liệt</small>
                                    <span class="fw-bold text-danger">@item.TotalCriticalQuestions</span>
                                </div>
                            </div>
                        </div>

                        @* Danh sách chương (Ma trận đề) *@
                        <div class="mt-2">
                            <h6 class="fw-bold small text-primary mb-2"><i class="bi bi-diagram-3 me-1"></i>MA TRẬN CHƯƠNG:</h6>
                            <div class="d-flex flex-wrap gap-1">
                                @if (item.QuestionTopics != null && item.QuestionTopics.Any())
                                {
                                    @foreach (var topic in item.QuestionTopics)
                                    {
                                        <span class="badge border text-dark fw-normal bg-white" style="font-size: 0.75rem;">
                                            @topic.Name (@topic.NumberOfQuestionsInExam)
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small italic">Chưa cấu hình chương</span>
                                }
                            </div>
                        </div>
                    </div>
                    @* Footer hiển thị nhanh trạng thái *@
                    <div class="card-footer bg-white border-0 text-end pb-3">
                        <a asp-controller="Question" asp-action="Index" asp-route-categoryId="@item.Id" class="btn btn-link btn-sm text-decoration-none p-0">
                            Xem kho câu hỏi <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .custom-hover-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border-color: #f0f0f0;
    }

        .custom-hover-card:hover {
            transform: translateY(-8px);
            border-color: #0d6efd;
            box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
        }

    .badge {
        font-weight: 600;
    }
</style>