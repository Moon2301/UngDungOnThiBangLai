@model UngDungOnThiBangLai.Models.CreateQuestionViewModel

@{
    ViewData["Title"] = "Chỉnh sửa câu hỏi";
    // Lấy URL ảnh cũ từ ViewBag hoặc Model để hiển thị
    string currentQuestionImg = ViewBag.ImageUrl as string;
    bool hasQuestionImg = !string.IsNullOrEmpty(currentQuestionImg);
}

<style>
    /* 1. HIỆU ỨNG HOVER ĐẬM VIỀN CHO KHUNG DRAG (Thêm mới/Cập nhật) */
    .drop-zone {
        border: 2px dashed #ffc107; /* Viền vàng mặc định cho trang Edit */
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        background: #fffdf5;
        cursor: pointer;
        transition: all 0.2s ease-in-out; /* Thêm transition mượt mà */
        min-height: 150px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
    }

        /* Hiệu ứng khi hover chuột vào */
        .drop-zone:hover {
            border: 2px solid #ffc107; /* Chuyển thành viền liền */
            background-color: #fff9e6; /* Đổi màu nền nhẹ */
            box-shadow: 0 0 10px rgba(255, 193, 7, 0.2); /* Thêm đổ bóng nhẹ */
        }

        /* Hiệu ứng khi đang kéo file đè lên */
        .drop-zone.dragover {
            border: 3px solid #0d6efd; /* Viền đậm hơn, màu xanh lam */
            background-color: #e9ecef;
            box-shadow: 0 0 15px rgba(13, 110, 253, 0.3);
        }

    .preview-img {
        max-height: 150px;
        border-radius: 5px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .answer-image-section {
        margin-top: 10px;
    }

    .small-zone {
        padding: 10px;
        min-height: 100px;
    }
    /* Style cho các nút xóa ở tiêu đề */
    .btn-remove-image {
        padding: 0 5px;
        font-size: 0.8rem;
    }
</style>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-warning"><i class="bi bi-pencil-square"></i> CHỈNH SỬA CÂU HỎI</h2>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <form asp-action="Edit" asp-route-id="@ViewBag.CurrentId" method="post" enctype="multipart/form-data" id="mainForm">
        @Html.AntiForgeryToken()
        @* Quan trọng: Lưu Id câu hỏi ẩn *@
        <input type="hidden" name="Id" value="@ViewBag.CurrentId" />

        <div class="row">
            <div class="col-md-7">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-primary">Nội dung văn bản</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề câu hỏi</label>
                            <textarea asp-for="QuestionText" class="form-control" rows="4" required></textarea>
                            <span asp-validation-for="QuestionText" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-success">Giải thích</label>
                            <textarea asp-for="Explanation" class="form-control" rows="2"></textarea>
                        </div>

                        <div class="form-check form-switch p-3 bg-light rounded border">
                            <input asp-for="IsCritical" class="form-check-input ms-0 me-2" type="checkbox">
                            <label class="form-check-label fw-bold text-danger">Câu hỏi ĐIỂM LIỆT</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-primary">Cấu hình & Ảnh minh họa</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Hạng bằng lái</label>
                            <select asp-for="LicenseCategoryId" class="form-select shadow-sm" required>
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-bold mb-0">Ảnh câu hỏi (Thả ảnh mới để đổi)</label>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-image @(hasQuestionImg ? "" : "d-none")" id="remove-question-img">
                                    <i class="bi bi-trash"></i> Xóa ảnh
                                </button>
                            </div>

                            <div class="drop-zone" id="question-drop-zone">
                                @* Nếu có ảnh cũ, ẩn info và hiện ảnh luôn *@
                                <div class="drop-info @(hasQuestionImg ? "d-none" : "")">
                                    <i class="bi bi-cloud-arrow-up fs-1 text-warning"></i>
                                    <p class="small mb-0 mt-2">Kéo thả hoặc click chọn ảnh mới</p>
                                </div>
                                <input type="file" asp-for="ImageFile" class="d-none sign-img-input" accept="image/*">
                                <img src="@currentQuestionImg" class="preview-img @(hasQuestionImg ? "" : "d-none") mt-2 mx-auto">

                                @* Hidden Input lưu URL ảnh cũ cho Câu hỏi *@
                                <input type="hidden" name="ImageUrl" value="@currentQuestionImg" id="QuestionImageUrl" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-5">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-primary">Danh sách đáp án</h5>
                <button type="button" id="add-answer" class="btn btn-primary btn-sm rounded-pill px-3">
                    <i class="bi bi-plus-circle"></i> Thêm đáp án
                </button>
            </div>
            <div class="card-body">
                <div id="answer-container">
                    @for (int i = 0; i < Model.Answers.Count; i++)
                    {
                        var hasImg = !string.IsNullOrEmpty(Model.Answers[i].imgUrl);
                        <div class="answer-item card p-3 mb-3 border border-light-subtle shadow-sm">
                            <div class="row align-items-center g-3">
                                <div class="col-auto">
                                    <div class="input-group-text bg-white border-0">
                                        <input type="radio" name="CorrectAnswerIndex" value="@i" @(Model.Answers[i].IsCorrect ? "checked" : "") class="form-check-input">
                                        <span class="ms-2 small fw-bold">Đúng</span>
                                    </div>
                                </div>
                                <div class="col">
                                    <input type="text" name="Answers[@i].AnswerText" value="@Model.Answers[i].AnswerText" class="form-control" required>
                                </div>
                                <div class="col-auto">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input toggle-image" type="checkbox" id="toggleImg@i" @(hasImg ? "checked" : "")>
                                        <label class="form-check-label small text-muted" for="toggleImg@i">Có ảnh</label>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <button type="button" class="btn btn-link text-danger remove-answer p-0 @(i == 0 ? "d-none" : "")"><i class="bi bi-trash fs-5"></i></button>
                                </div>
                            </div>

                            <div class="answer-image-section" style="@(hasImg ? "display:block" : "display:none")">
                                <div class="d-flex justify-content-between align-items-center mt-3 mb-1">
                                    <p class="small mb-0 text-muted fw-bold">Ảnh đáp án</p>
                                    <button type="button" class="btn btn-link btn-sm text-danger btn-remove-image p-0 text-decoration-none @(hasImg ? "" : "d-none")">
                                        <i class="bi bi-x-circle"></i> Bỏ ảnh
                                    </button>
                                </div>
                                <div class="drop-zone small-zone">
                                    <div class="drop-info @(hasImg ? "d-none" : "")">
                                        <p class="small mb-0 text-muted">Kéo thả hoặc click chọn ảnh</p>
                                    </div>
                                    <input type="file" name="Answers[@i].ImageFile" class="d-none sign-img-input" accept="image/*">
                                    @* Hiển thị ảnh cũ của đáp án *@
                                    <img src="@Model.Answers[i].imgUrl" class="preview-img @(hasImg ? "" : "d-none") mx-auto" style="max-height: 80px;">
                                    @* Hidden Input lưu URL ảnh cũ cho Đáp án *@
                                    <input type="hidden" name="Answers[@i].ImageUrl" value="@Model.Answers[i].imgUrl" />
                                </div>
                            </div>
                            <input type="hidden" name="Answers[@i].IsCorrect" value="@(Model.Answers[i].IsCorrect ? "true" : "false")">
                        </div>
                    }
                </div>

                <div class="mt-4 border-top pt-3 text-end">
                    <button type="submit" class="btn btn-warning btn-lg px-5 shadow rounded-pill fw-bold">CẬP NHẬT CÂU HỎI</button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Lấy index hiện tại dựa trên số lượng đáp án đang có
            let answerIndex = @Model.Answers.Count;

            function initDragAndDrop(container) {
                const dropZone = container.find('.drop-zone');
                const fileInput = container.find('.sign-img-input');
                const previewImg = container.find('.preview-img');
                const dropInfo = container.find('.drop-info');
                // Tìm nút xóa ở tiêu đề gần nhất
                const removeBtn = container.closest('.mb-3, .answer-image-section').find('.btn-remove-image');

                dropZone.off('click').on('click', function () {
                    fileInput.trigger('click');
                });

                dropZone.on('dragover', function (e) {
                    e.preventDefault();
                    $(this).addClass('dragover'); // CSS sẽ lo hiệu ứng đậm viền
                });

                dropZone.on('dragleave drop', function () {
                    $(this).removeClass('dragover');
                });

                dropZone.on('drop', function (e) {
                    e.preventDefault();
                    const files = e.originalEvent.dataTransfer.files;
                    if (files.length > 0) {
                        fileInput[0].files = files;
                        handlePreview(files[0], previewImg, dropInfo, removeBtn);
                    }
                });

                fileInput.on('change', function () {
                    if (this.files.length > 0) {
                        handlePreview(this.files[0], previewImg, dropInfo, removeBtn);
                    }
                });
            }

            function handlePreview(file, previewImg, dropInfo, removeBtn) {
                if (!file.type.startsWith('image/')) return;
                const reader = new FileReader();
                reader.onload = (e) => {
                    previewImg.attr('src', e.target.result).removeClass('d-none');
                    if (dropInfo) dropInfo.addClass('d-none');
                    if (removeBtn) removeBtn.removeClass('d-none'); // Hiện nút xóa ở tiêu đề
                };
                reader.readAsDataURL(file);
            }

            // Sự kiện nút xóa ảnh (Dùng cho cả câu hỏi và đáp án ở trang Edit)
            $(document).on('click', '.btn-remove-image', function(e) {
                e.preventDefault();
                const container = $(this).closest('.mb-3, .answer-image-section');
                const fileInput = container.find('.sign-img-input');
                const previewImg = container.find('.preview-img');
                const dropInfo = container.find('.drop-info');

                // 1. Reset file input (xóa file mới nếu có)
                fileInput.val('');
                // 2. Ẩn ảnh preview và hiện info
                previewImg.attr('src', '#').addClass('d-none');
                dropInfo.removeClass('d-none');
                // 3. Ẩn chính nút xóa
                $(this).addClass('d-none');

                // 4. (QUAN TRỌNG CHO EDIT) Xóa giá trị ảnh cũ trong hidden field
                container.find('input[type="hidden"][name$=".ImageUrl"]').val('');
            });

            // Khởi tạo cho tất cả các vùng khi Load trang
            initDragAndDrop($('#question-drop-zone').parent());
            $('.answer-item').each(function() {
                initDragAndDrop($(this).find('.answer-image-section'));
            });

            // Toggle Image Switch
            $(document).on('change', '.toggle-image', function () {
                const section = $(this).closest('.answer-item').find('.answer-image-section');
                if (this.checked) {
                    section.slideDown(250);
                } else {
                    section.slideUp(200);
                    // Khi tắt switch, tự động kích hoạt sự kiện xóa ảnh để clear dữ liệu
                    section.find('.btn-remove-image').trigger('click');
                }
            });

            // Thêm đáp án (Giống trang Create)
            $("#add-answer").click(function () {
                let html = `
                    <div class="answer-item card p-3 mb-3 border border-light-subtle shadow-sm" style="display:none">
                        <div class="d-flex align-items-center gap-3">
                            <div class="input-group-text bg-white border-0">
                                <input type="radio" name="CorrectAnswerIndex" value="${answerIndex}" class="form-check-input">
                                <span class="ms-2 small fw-bold">Đúng</span>
                            </div>
                            <input type="text" name="Answers[${answerIndex}].AnswerText" class="form-control" placeholder="Nhập nội dung đáp án..." required>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input toggle-image" type="checkbox" id="toggleImg${answerIndex}">
                                <label class="form-check-label small text-muted" for="toggleImg${answerIndex}">Có ảnh</label>
                            </div>
                            <button type="button" class="btn btn-outline-danger remove-answer btn-sm"><i class="bi bi-trash"></i></button>
                        </div>
                        <div class="answer-image-section">
                             <div class="d-flex justify-content-between align-items-center mt-3 mb-1">
                                <p class="small mb-0 text-muted fw-bold">Ảnh đáp án</p>
                                <button type="button" class="btn btn-link btn-sm text-danger btn-remove-image d-none p-0 text-decoration-none">
                                    <i class="bi bi-x-circle"></i> Bỏ ảnh
                                </button>
                            </div>
                            <div class="drop-zone small-zone">
                                <div class="drop-info">
                                    <p class="small mb-0 text-muted">Kéo thả hoặc click chọn ảnh</p>
                                </div>
                                <input type="file" name="Answers[${answerIndex}].ImageFile" class="d-none sign-img-input" accept="image/*">
                                <img src="#" class="preview-img d-none mx-auto" style="max-height: 80px;">
                            </div>
                        </div>
                        <input type="hidden" name="Answers[${answerIndex}].IsCorrect" value="false">
                    </div>`;
                const $newItem = $(html);
                $("#answer-container").append($newItem);
                $newItem.fadeIn(300);
                // Khởi tạo kéo thả cho vùng ảnh của item mới
                initDragAndDrop($newItem.find('.answer-image-section'));
                answerIndex++;
            });

            // Xóa đáp án
            $(document).on("click", ".remove-answer", function () {
                const item = $(this).closest(".answer-item");
                item.fadeOut(200, function() {
                    $(this).remove();
                    reIndexAnswers(); // Đánh lại index để đảm bảo gửi mảng liên tục
                });
            });

            function reIndexAnswers() {
                $('.answer-item').each(function(idx) {
                    $(this).find('input[type="radio"]').val(idx);
                    $(this).find('input[type="text"]').attr('name', `Answers[${idx}].AnswerText`);
                    $(this).find('input[type="file"]').attr('name', `Answers[${idx}].ImageFile`);
                    $(this).find('input[type="hidden"][name$=".IsCorrect"]').attr('name', `Answers[${idx}].IsCorrect`);
                    // Quan trọng cho Edit: đánh lại hidden URL
                    $(this).find('input[type="hidden"][name$=".ImageUrl"]').attr('name', `Answers[${idx}].ImageUrl`);
                    $(this).find('.toggle-image').attr('id', `toggleImg${idx}`);
                    $(this).find('label.toggle-image').attr('for', `toggleImg${idx}`);
                });
                answerIndex = $('.answer-item').length;
            }

            // Trước khi gửi Form: Cập nhật flag IsCorrect
            $("#mainForm").submit(function () {
                let selectedIndex = $("input[name='CorrectAnswerIndex']:checked").val();
                $("input[name$='.IsCorrect']").val("false");
                if (selectedIndex !== undefined) {
                    $(`input[name='Answers[${selectedIndex}].IsCorrect']`).val("true");
                }
            });
        });
    </script>
}